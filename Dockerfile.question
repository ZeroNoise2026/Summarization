FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY config.py .
COPY shared/ shared/
COPY question/ question/

# Cloud Run sets $PORT (default 8080). Locally override with -e PORT=8003.
ENV PORT=8080
EXPOSE 8080

CMD exec uvicorn question.main:app --host 0.0.0.0 --port ${PORT}
