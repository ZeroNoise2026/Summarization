SUPABASE_KEY=your-supabase-service-role-key

# Moonshot (Kimi) API
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# ═══ Summary Service ═══
MOONSHOT_MODEL=kimi-k2.5
